{
  "name": "dorv",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "ci": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "dev": "pnpm --filter @dorv/extension dev",
    "e2e": "playwright test --project=mocked",
    "e2e:ci": "playwright test --project=mocked:ci",
    "e2e:real": "playwright test --project=real",
    "e2e:build": "pnpm --filter @dorv/extension build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "prepare": "command -v prek >/dev/null 2>&1 && prek install || true",
    "precommit": "prek run --all-files",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "zip": "pnpm --filter @dorv/extension zip"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@playwright/test": "^1.52.0",
    "@sentry/browser": "^10.53.1",
    "@types/chrome": "^0.1.42",
    "@types/node": "^22.15.18",
    "eslint": "^9.27.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4"
  }
}
