# ── Build-time (required) ────────────────────────────────────────────────
# OAuth client ID for chrome.identity. Used in wxt.config.ts at build time.
GOOGLE_CLIENT_ID=

# ── Sentry (optional) ─────────────────────────────────────────────────────
# Set these to enable error tracking in the release build.
# WXT automatically reads variables prefixed with WXT_ from the environment.
# WXT_SENTRY_DSN=https://key@o0.ingest.sentry.io/0
# WXT_SENTRY_ENVIRONMENT=production

# ── Chrome Web Store release automation ───────────────────────────────────
# Used by .github/workflows/release.yml. Set as repository secrets, not .env.
# CWS_CLIENT_ID=
# CWS_CLIENT_SECRET=
# CWS_REFRESH_TOKEN=
# CWS_PUBLISHER_ID=
# CWS_EXTENSION_ID=

# ── E2E real-credential tests (local only) ─────────────────────────────────
# Set these in .env.test.local (gitignored). Used by pnpm e2e:real.
# DORV_GITHUB_PAT=github_pat_...
# DORV_GOOGLE_REFRESH_TOKEN=1//...
# DORV_GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# DORV_GOOGLE_CLIENT_SECRET=GOCSPX-...
# DORV_TEST_REPO=ahnpolished/dorv
# DORV_TEST_PR_NUMBER=6

# ── Others ─────────────────────────────────────────────────────────────────
# Empty for v0.2.0 DirectAdapter. Set later for managed BackendAdapter installs.
# BACKEND_URL=
