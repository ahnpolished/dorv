{
  "name": "@dorv/extension",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wxt build",
    "dev": "wxt",
    "chrome-dev-setup": "/Applications/Google\\ Chrome.app/Contents/MacOS/Google\\ Chrome --user-data-dir=\"$HOME/.dorv-dev-chrome-profile\" --profile-directory=Default about:blank &",
    "dev:chrome-fresh": "bash scripts/dev-chrome-fresh.sh",
    "dev:loop": "node scripts/dev-loop.mjs",
    "chrome-debug": "open -a 'Google Chrome' --args --remote-debugging-port=9222",
    "zip": "wxt zip"
  },
  "dependencies": {
    "@sentry/browser": "^10.53.1",
    "@wxt-dev/module-react": "1.1.3",
    "lucide-react": "^1.23.0",
    "marked": "^18.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "wxt": "^0.20.6"
  },
  "devDependencies": {
    "@types/marked": "^6.0.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "dotenv": "^16.0.0",
    "ws": "^8.21.0"
  }
}
