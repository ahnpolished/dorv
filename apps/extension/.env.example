# Google OAuth 2.0 Client ID (Chrome Extension type)
#
# How to get one:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID of type "Chrome Extension"
# 3. Add these Extension IDs:
#      - dnhkakgmedpnllpbmjlacjadljcfhlil  (development)
#      - kgbhbgnalibgfjdfpkmpicmpmahpbona  (Chrome Web Store)
# 4. Copy the generated client ID here (looks like 123456789-xxxxx.apps.googleusercontent.com)
# 5. The extension uses your Chrome profile account — make sure you're signed into
#    Chrome with the Google account you want to use.
#
# Required APIs & Services (enable in Google Cloud Console):
#   - Google Drive API
#   - Google Docs API
#
# Required OAuth scopes (auto-configured in wxt.config.ts):
#   - https://www.googleapis.com/auth/drive.file (create/manage own files)
#   - profile (display name + avatar)
#   - email (display email)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
WXT_SENTRY_DSN=
WXT_SENTRY_ENVIRONMENT=development
DORV_GITHUB_PAT=github_pat_placeholder
DORV_GOOGLE_TOKEN=ya29.placeholder
DORV_TEST_REPO=ahnpolished/dorv
DORV_TEST_PR_NUMBER=6
