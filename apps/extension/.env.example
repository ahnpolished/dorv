# Google OAuth 2.0 Client ID (Chrome Extension type)
#
# How to get one:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID of type "Chrome Extension"
# 3. Add the Extension ID from chrome://extensions for your loaded instance:
#      - When loading unpacked: the ID shown in chrome://extensions
#        (the stable dev key produces: ndkhkamgdenpllbpjmaljcdajlfclhli)
#      - Chrome Web Store: the published extension ID
# 4. Copy the generated client ID here (looks like 123456789-xxxxx.apps.googleusercontent.com)
# 5. MUST also add the redirect URI pattern under "Authorized redirect URIs":
#      https://<extension-id>.chromiumapp.org/
#    (Chrome uses this for the OAuth callback; without it you get 400 invalid_request)
# 6. The extension uses your Chrome profile account — make sure you're signed into
#    Chrome with the Google account you want to use.
#
# ⚠️  COMMON PITFALLS:
#   - "Error 400: invalid_request" → the extension ID isn't registered in the OAuth client
#     OR the redirect URI pattern is missing from Authorized redirect URIs
#   - OAuth consent screen must be configured (go to "OAuth consent screen" tab)
#   - Publishing status: doesn't need to be published — "Testing" is fine for development
#
# Required APIs & Services (enable in Google Cloud Console):
#   - Google Drive API
#   - Google Docs API
#
# Required OAuth scopes (auto-configured in wxt.config.ts):
#   - https://www.googleapis.com/auth/drive.file (create/manage own files)
#   - profile (display name + avatar)
#   - email (display email)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
WXT_SENTRY_DSN=
WXT_SENTRY_ENVIRONMENT=development
DORV_GITHUB_PAT=github_pat_placeholder
DORV_GOOGLE_TOKEN=ya29.placeholder
DORV_TEST_REPO=ahnpolished/dorv
DORV_TEST_PR_NUMBER=6
